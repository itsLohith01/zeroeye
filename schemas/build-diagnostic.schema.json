{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lobster-trap/zeroeye/schemas/build-diagnostic.schema.json",
  "title": "Build Diagnostic Metadata",
  "description": "Schema for diagnostic/build-*.json files generated by build.py alongside encrypted .logd diagnostic artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "commit",
    "diagnostic_logd",
    "diagnostic_logd_error",
    "chunked",
    "chunk_size_bytes",
    "password",
    "decrypt_command",
    "total_modules",
    "passed",
    "failed",
    "modules",
    "pr_note"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the diagnostic metadata was generated."
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}$",
      "description": "Short commit identifier used in diagnostic artifact filenames."
    },
    "diagnostic_logd": {
      "description": "Relative path to the encrypted diagnostic .logd artifact, a list of chunk paths, or null when logd creation failed.",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^diagnostic/build-[0-9a-f]{8}.*\\.logd$"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^diagnostic/build-[0-9a-f]{8}.*\\.logd$"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "diagnostic_logd_error": {
      "description": "Error text explaining why the .logd artifact was not created, or null on success.",
      "type": [
        "string",
        "null"
      ]
    },
    "chunked": {
      "type": "boolean",
      "description": "Whether the .logd artifact was split into multiple chunks."
    },
    "chunk_size_bytes": {
      "description": "Chunk size used when chunked is true; null when the .logd is not chunked.",
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "password": {
      "description": "Password required to decrypt the .logd artifact, or null if no encrypted artifact was created.",
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decrypt_command": {
      "description": "Command example for unpacking the encrypted diagnostic artifact, or null if unavailable.",
      "type": [
        "string",
        "null"
      ]
    },
    "total_modules": {
      "type": "integer",
      "minimum": 0
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "elapsed_seconds",
          "artifact",
          "output"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL"
            ]
          },
          "elapsed_seconds": {
            "type": "number",
            "minimum": 0
          },
          "artifact": {
            "type": [
              "string",
              "null"
            ]
          },
          "output": {
            "type": "string"
          }
        }
      }
    },
    "pr_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
